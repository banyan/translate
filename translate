#!/usr/bin/env -S deno run --allow-env --allow-net --allow-run=pbcopy

type ChatMessage = {
  role: "system" | "user";
  content: string;
};

const SYSTEM_PROMPT = [
  "You are a translator. Translate the following Japanese text to natural English.",
  "Output ONLY the translation. No explanations, no quotes, no commentary, no prefixes like 'Here is the translation:'.",
  "Wrap code-level identifiers like database column names, table names, and variable names in backticks (e.g., `user_id`, `created_at`). Do NOT wrap product names or general technical terms like Hasura, React, API in backticks.",
  "If the input is a mix of Japanese and English, translate everything into English.",
  "Insert line breaks at natural topic or paragraph boundaries to aid readability. Do NOT break after every sentence; group related sentences together.",
].join("\n");

export function buildMessages(input: string): ChatMessage[] {
  return [
    { role: "system", content: SYSTEM_PROMPT },
    { role: "user", content: input },
  ];
}

export function extractTranslation(body: unknown): string {
  if (!body || typeof body !== "object") {
    throw new Error("Invalid API response");
  }
  const choices = (body as { choices?: unknown[] }).choices;
  if (!Array.isArray(choices) || choices.length === 0) {
    throw new Error("No choices in API response");
  }
  const first = choices[0] as { message?: { content?: string } };
  const content = first?.message?.content;
  if (typeof content !== "string") {
    throw new Error("No content in API response");
  }
  return content.trim();
}

export type HistoryEntry = {
  ts: string;
  input: string;
  output: string;
};

export function serializeHistoryEntry(entry: HistoryEntry): string {
  return JSON.stringify(entry) + "\n";
}

export function resolveHistoryPath(): string {
  const home = Deno.env.get("HOME");
  if (!home) {
    throw new Error("HOME environment variable is not set");
  }
  return `${home}/.local/state/translate/history.jsonl`;
}

type CallOptions = {
  apiKey: string;
  model: string;
  input: string;
  fetchImpl?: typeof fetch;
};

const BASE_URL = "https://openrouter.ai/api/v1";

export async function callOpenRouter(options: CallOptions): Promise<string> {
  const { apiKey, model, input, fetchImpl = fetch } = options;
  const messages = buildMessages(input);

  const response = await fetchImpl(`${BASE_URL}/chat/completions`, {
    method: "POST",
    headers: {
      Authorization: `Bearer ${apiKey}`,
      "Content-Type": "application/json",
      "X-Title": "translate",
    },
    body: JSON.stringify({
      model,
      messages,
      temperature: 0.2,
    }),
  });

  if (!response.ok) {
    const text = await response.text();
    throw new Error(`API error (${response.status}): ${text.slice(0, 200)}`);
  }

  const body = await response.json();
  return extractTranslation(body);
}

export async function copyToClipboard(text: string): Promise<void> {
  const command = new Deno.Command("pbcopy", { stdin: "piped" });
  const child = command.spawn();
  const writer = child.stdin.getWriter();
  await writer.write(new TextEncoder().encode(text));
  await writer.close();
  const status = await child.status;
  if (!status.success) {
    throw new Error("pbcopy failed");
  }
}

const DEFAULT_MODEL = "anthropic/claude-4.6-sonnet";

async function main(): Promise<number> {
  const apiKey = Deno.env.get("OPENROUTER_API_KEY");
  if (!apiKey) {
    console.error("Error: OPENROUTER_API_KEY is not set");
    return 1;
  }

  const model = Deno.env.get("TRANSLATE_MODEL") || DEFAULT_MODEL;

  while (true) {
    const input = prompt(">");
    if (input === null) {
      // Ctrl+D
      break;
    }

    const trimmed = input.trim();
    if (!trimmed) {
      continue;
    }

    try {
      const translation = await callOpenRouter({ apiKey, model, input: trimmed });
      console.log(translation);
      await copyToClipboard(translation);
      // clipboard copy is silent
    } catch (error) {
      console.error(error instanceof Error ? error.message : String(error));
    }
  }

  return 0;
}

if (import.meta.main) {
  Deno.exit(await main());
}
